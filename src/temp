   #pragma once
#include <Arduino.h>

static constexpr uint8_t ESPNOW_CHANNEL = 1;

#ifndef SLAVE_ID
#define SLAVE_ID 0
#endif

static constexpr uint8_t THIS_SLAVE_ID = SLAVE_ID;

// ===== MAC-адреса 4 слейвов =====
// ОБЯЗАТЕЛЬНО замени на реальные MAC твоих ESP32-C3
static const uint8_t SLAVE_MACS[4][6] = {
    {0xB0, 0xA6, 0x04, 0x06, 0xD4, 0x74}, // slave0
    {0x08, 0x92, 0x72, 0x84, 0x39, 0xA4}, // slave1
    {0x88, 0x56, 0xA6, 0x78, 0xA4, 0xB4}, // slave2
    {0x08, 0x92, 0x72, 0x84, 0x3E, 0x58}  // slave3
};

// ===== Пины 4 серв на одном ESP32-C3 =====
// Подставь свои реальные GPIO
// Локальный порядок серво:
// index 0 -> row 0, col 0
// index 1 -> row 0, col 1
// index 2 -> row 1, col 0
// index 3 -> row 1, col 1
static constexpr int SERVO_PINS[4] = {2, 3, 4, 5};

// ===== Углы =====
static constexpr uint8_t CENTER_ANGLE = 90;
static constexpr uint8_t OPEN_DELTA = 35; // как ты просил: +35 градусов

// ===== Тайминги =====
static constexpr uint16_t HOLD_MS = 220;       // сколько серво держать открытой
static constexpr uint16_t STEP_DELAY_MS = 260; // шаг паттерна на мастере

// ===== Глобальная матрица =====
static constexpr uint8_t GLOBAL_ROWS = 4;
static constexpr uint8_t GLOBAL_COLS = 4;
static constexpr uint8_t LOCAL_ROWS = 2;
static constexpr uint8_t LOCAL_COLS = 2;


#pragma once
#include <Arduino.h>

struct ServoCommand {
    uint8_t servoIndex;   // 0..3
    uint16_t holdMs;      // сколько держать открытой
};

#include <Arduino.h>
#include <WiFi.h>
#include <esp_now.h>
#include "config.h"
#include "protocol.h"

// --------------------------------------------------
// Настройки кнопки
// --------------------------------------------------

static constexpr uint8_t BUTTON_PIN = 18;

// --------------------------------------------------
// ESP-NOW helpers
// --------------------------------------------------

bool addPeer(const uint8_t mac[6]) {
    esp_now_peer_info_t peer = {};
    memcpy(peer.peer_addr, mac, 6);
    peer.channel = 0;      // использовать текущий канал
    peer.encrypt = false;

    esp_err_t result = esp_now_add_peer(&peer);
    return (result == ESP_OK || result == ESP_ERR_ESPNOW_EXIST);
}

void onDataSent(const uint8_t* mac_addr, esp_now_send_status_t status) {
    Serial.printf("Send status: %s\n",
                  status == ESP_NOW_SEND_SUCCESS ? "OK" : "FAIL");
}

bool sendServoCommand(uint8_t slaveId, uint8_t servoIndex, uint16_t holdMs) {
    ServoCommand cmd;
    cmd.servoIndex = servoIndex;
    cmd.holdMs = holdMs;

    esp_err_t result = esp_now_send(
        SLAVE_MACS[slaveId],
        reinterpret_cast<const uint8_t*>(&cmd),
        sizeof(cmd)
    );

    if (result != ESP_OK) {
        Serial.printf("Send failed: slave=%u servo=%u err=%d\n",
                      slaveId, servoIndex, result);
        return false;
    }

    Serial.printf("Sent: slave=%u servo=%u hold=%u\n",
                  slaveId, servoIndex, holdMs);
    return true;
}

// --------------------------------------------------
// Mapping: global 4x4 -> slave + local servo
// --------------------------------------------------

void mapGlobalCellToSlave(
    uint8_t row,
    uint8_t col,
    uint8_t& slaveId,
    uint8_t& servoIndex
) {
    slaveId = (row / 2) * 2 + (col / 2);

    uint8_t localRow = row % 2;
    uint8_t localCol = col % 2;

    servoIndex = localRow * 2 + localCol;
}

// --------------------------------------------------
// Pattern
// --------------------------------------------------

void runSnakeOnce() {
    Serial.println("Run SNAKE start");

    for (uint8_t row = 0; row < GLOBAL_ROWS; row++) {
        if ((row % 2) == 0) {
            // слева направо
            for (uint8_t col = 0; col < GLOBAL_COLS; col++) {
                uint8_t slaveId = 0;
                uint8_t servoIndex = 0;

                mapGlobalCellToSlave(row, col, slaveId, servoIndex);
                sendServoCommand(slaveId, servoIndex, HOLD_MS);
                delay(STEP_DELAY_MS);
            }
        } else {
            // справа налево
            for (int col = GLOBAL_COLS - 1; col >= 0; col--) {
                uint8_t slaveId = 0;
                uint8_t servoIndex = 0;

                mapGlobalCellToSlave(row, static_cast<uint8_t>(col), slaveId, servoIndex);
                sendServoCommand(slaveId, servoIndex, HOLD_MS);
                delay(STEP_DELAY_MS);
            }
        }
    }

    Serial.println("Run SNAKE done");
}

// --------------------------------------------------
// Button helpers
// Кнопка подключена между GPIO18 и GND
// INPUT_PULLUP:
//   не нажата -> HIGH
//   нажата    -> LOW
// --------------------------------------------------

bool isButtonPressed() {
    return digitalRead(BUTTON_PIN) == LOW;
}

// --------------------------------------------------
// setup / loop
// --------------------------------------------------

void setup() {
    Serial.begin(115200);
    delay(1000);

    Serial.println("\n=== MASTER START ===");

    // Кнопка
    pinMode(BUTTON_PIN, INPUT_PULLUP);

    // ESP-NOW
    WiFi.mode(WIFI_STA);

    Serial.print("Master MAC: ");
    Serial.println(WiFi.macAddress());

    if (esp_now_init() != ESP_OK) {
        Serial.println("esp_now_init failed");
        while (true) {
            delay(1000);
        }
    }

    esp_now_register_send_cb(onDataSent);

    for (int i = 0; i < 4; i++) {
        if (!addPeer(SLAVE_MACS[i])) {
            Serial.printf("addPeer failed: %d\n", i);
            while (true) {
                delay(1000);
            }
        }
    }

    Serial.println("ESP-NOW ready");
    Serial.println("Button on GPIO 18");
    Serial.println("Press button to run snake");
}

void loop() {
    if (isButtonPressed()) {
        delay(30); // антидребезг

        if (isButtonPressed()) {
            Serial.println("Button pressed");
            runSnakeOnce();

            // ждать, пока кнопку отпустят
            while (isButtonPressed()) {
                delay(10);
            }

            delay(30); // антидребезг после отпускания
            Serial.println("Button released");
        }
    }

    delay(5);
}


#include <Arduino.h>
#include <WiFi.h>
#include <esp_now.h>
#include <ESP32Servo.h>
#include "config.h"
#include "protocol.h"

Servo servos[4];

// --------------------------------------------------
// Servo helpers
// --------------------------------------------------

uint8_t clampAngle(int value) {
    if (value < 0) return 0;
    if (value > 180) return 180;
    return static_cast<uint8_t>(value);
}

void moveServoSmooth(uint8_t servoIndex, uint8_t targetAngle, uint8_t stepDelayMs = 4) {
    if (servoIndex >= 4) return;

    int currentAngle = servos[servoIndex].read();

    if (currentAngle < targetAngle) {
        for (int angle = currentAngle; angle <= targetAngle; angle++) {
            servos[servoIndex].write(angle);
            delay(stepDelayMs);
        }
    } else {
        for (int angle = currentAngle; angle >= targetAngle; angle--) {
            servos[servoIndex].write(angle);
            delay(stepDelayMs);
        }
    }
}

void closeServo(uint8_t servoIndex) {
    if (servoIndex >= 4) return;
    moveServoSmooth(servoIndex, CENTER_ANGLE, 8);
}

void openServo(uint8_t servoIndex) {
    if (servoIndex >= 4) return;
    uint8_t angle = clampAngle(CENTER_ANGLE + OPEN_DELTA);
    moveServoSmooth(servoIndex, angle, 8);
}

void initServos() {
    ESP32PWM::allocateTimer(0);
    ESP32PWM::allocateTimer(1);
    ESP32PWM::allocateTimer(2);
    ESP32PWM::allocateTimer(3);

    for (int i = 0; i < 4; i++) {
        servos[i].setPeriodHertz(50);
        servos[i].attach(SERVO_PINS[i], 500, 2400);
        servos[i].write(CENTER_ANGLE);
    }

    delay(300);
}

// --------------------------------------------------
// ESP-NOW callback
// --------------------------------------------------

void onDataRecv(const uint8_t* mac_addr, const uint8_t* data, int len) {
    if (len != sizeof(ServoCommand)) {
        Serial.printf("Wrong packet size: %d\n", len);
        return;
    }

    ServoCommand cmd;
    memcpy(&cmd, data, sizeof(cmd));

    if (cmd.servoIndex >= 4) {
        Serial.printf("Wrong servo index: %u\n", cmd.servoIndex);
        return;
    }

    Serial.printf("Recv: servo=%u hold=%u\n", cmd.servoIndex, cmd.holdMs);

    openServo(cmd.servoIndex);
    delay(cmd.holdMs);
    closeServo(cmd.servoIndex);

    Serial.printf("Done: servo=%u\n", cmd.servoIndex);
}

// --------------------------------------------------
// setup / loop
// --------------------------------------------------

void setup() {
    Serial.begin(115200);
    delay(1000);

    Serial.printf("\n=== SLAVE START, ID=%u ===\n", THIS_SLAVE_ID);

    initServos();

    WiFi.mode(WIFI_STA);

    Serial.print("Slave MAC: ");
    Serial.println(WiFi.macAddress());

    if (esp_now_init() != ESP_OK) {
        Serial.println("esp_now_init failed");
        while (true) {
            delay(1000);
        }
    }

    esp_now_register_recv_cb(onDataRecv);
    Serial.println("ESP-NOW ready");
}

void loop() {
}

